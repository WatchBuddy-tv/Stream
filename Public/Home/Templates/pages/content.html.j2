{#- Bu araç @keyiflerolsun tarafından | @KekikAkademi için yazılmıştır. -#}
{% extends "_html_taban.html.j2" %}

{% block breadcrumbs %}
<nav class="breadcrumbs">
    <a href="/{{ provider_query if provider_query else '' }}" class="breadcrumbs-link"><i class="fas fa-home"></i> <span data-i18n="nav_home">{{ tr('nav_home') }}</span></a>
    <span class="breadcrumbs-sep">/</span>
    <a href="/eklenti/{{ eklenti_adi }}{{ provider_query }}" class="breadcrumbs-link">{{ eklenti_adi }}</a>
    <span class="breadcrumbs-sep">/</span>
    <span class="breadcrumbs-current">{{ content.title }}</span>
</nav>
{% endblock %}

{% block icerik %}
<section class="content-hero">
    <div class="content-hero-backdrop">
        <img src="{{ content.poster }}" alt="" loading="lazy" onerror="this.style.opacity='0'">
    </div>
    <div class="content-hero-info">
        <div class="content-poster-wrap{% if not content.poster %} has-error{% endif %}">
            {% if content.poster %}<img src="{{ content.poster }}" alt="{{ content.title }}" onerror="this.parentElement.classList.add('has-error');this.remove()">{% endif %}
        </div>
        <div class="content-meta">
            <h1 class="content-title">{{ content.title }}</h1>
            <div class="content-meta-row">
                {% if content.year %}<span class="content-meta-badge"><i class="fas fa-calendar-alt"></i> {{ content.year }}</span>{% endif %}
                {% if content.rating %}<span class="content-meta-badge"><i class="fas fa-star"></i> {{ content.rating }}</span>{% endif %}
                {% if content.duration %}<span class="content-meta-badge"><i class="fas fa-clock"></i> {{ content.duration }} {{ tr('minutes_suffix') }}</span>{% endif %}
                <span class="content-meta-badge"><i class="fas fa-puzzle-piece"></i> {{ eklenti_adi }}</span>
            </div>
            {% if content.description %}
            <p class="content-description">{{ content.description }}</p>
            {% endif %}
            {% if content.tags %}
            <div class="content-tags">{% for tag in (content.tags.split(',') if content.tags is string else content.tags) %}<span class="badge">{{ tag | trim }}</span>{% endfor %}</div>
            {% endif %}
            {% if content.actors %}
            <p class="content-actors"><strong>{{ tr('actors_label') }}:</strong> {{ content.actors if content.actors is string else content.actors | join(', ') }}</p>
            {% endif %}
            <div class="content-actions">
                {% if content.episodes and content.episodes|length > 0 %}
                <a href="#episodes-section" class="button button-primary" id="scroll-to-episodes"><i class="fas fa-list"></i> <span data-i18n="browse_episodes">{{ tr('browse_episodes') }}</span></a>
                {% else %}
                <a href="/izle/{{ eklenti_adi }}?url={{ content.url }}&baslik={{ content.title | urlencode }}&content_url={{ content.url }}&poster_url={{ content.poster | default('', true) | urlencode }}&year={{ content.year | default('', true) }}&rating={{ content.rating | default('', true) }}{{ provider_query_amp }}" class="button button-primary"><i class="fas fa-play"></i> <span data-i18n="watch_now">{{ tr('watch_now') }}</span></a>
                {% endif %}
                <a href="{{ provider_url if provider_url else '' }}/api/v1/load_item?plugin={{ eklenti_adi }}&encoded_url={{ content.url }}" target="_blank" class="button button-secondary"><i class="fas fa-code"></i> <span data-i18n="api_button">{{ tr('api_button') }}</span></a>
                <button class="button-icon" id="share-content-btn" title="{{ tr('share') }}" data-i18n="share" data-i18n-attr="title">
                    <i class="fas fa-share-alt"></i>
                </button>
            </div>
        </div>
    </div>
</section>

{% if content.episodes and content.episodes|length > 0 %}
<section class="episodes-section" id="episodes-section">
    <h2 class="section-title" data-i18n="episodes_title">{{ tr('episodes_title') }}</h2>

    {# Collect unique seasons from flat episode list #}
    {% set seasons = content.episodes | map(attribute='season') | select('ne', none) | unique | sort | list %}

    {% if seasons | length > 1 %}
    <div class="season-tabs" id="season-tabs">
        {% for s in seasons %}
        <button class="season-tab{% if loop.first %} active{% endif %}" data-season="{{ s }}">
            {{ tr('season_title').replace('{season}', s|string) }}
        </button>
        {% endfor %}
    </div>
    {% endif %}

    {% if seasons | length > 0 %}
        {% for s in seasons %}
        <div class="episode-grid season-panel{% if loop.first %} active{% endif %}" data-season="{{ s }}">
            {% for ep in content.episodes | selectattr('season', 'equalto', s) | sort(attribute='episode') %}
            <a href="/izle/{{ eklenti_adi }}?url={{ ep.url }}&baslik={{ content.title | urlencode }}&content_url={{ content.url }}&poster_url={{ content.poster | default('', true) | urlencode }}&year={{ content.year | default('', true) }}&rating={{ content.rating | default('', true) }}&season={{ ep.season | default('', true) }}&episode={{ ep.episode | default('', true) }}{{ provider_query_amp }}" class="episode-card" data-season="{{ ep.season | default('', true) }}" data-episode="{{ ep.episode | default(loop.index, true) }}">
                <span class="episode-number">{{ ep.episode or loop.index }}</span>
                <span class="episode-title">{{ ep.title or (tr('season_title').replace('{season}', s|string) ~ ' E' ~ (ep.episode or loop.index)|string) }}</span>
            </a>
            {% endfor %}
        </div>
        {% endfor %}
    {% else %}
        {# No season info — list all episodes flat #}
        <div class="episode-grid season-panel active" data-season="1">
            {% for ep in content.episodes | sort(attribute='episode') %}
            <a href="/izle/{{ eklenti_adi }}?url={{ ep.url }}&baslik={{ content.title | urlencode }}&content_url={{ content.url }}&poster_url={{ content.poster | default('', true) | urlencode }}&year={{ content.year | default('', true) }}&rating={{ content.rating | default('', true) }}&season={{ ep.season | default('', true) }}&episode={{ ep.episode | default('', true) }}{{ provider_query_amp }}" class="episode-card" data-season="{{ ep.season | default('1', true) }}" data-episode="{{ ep.episode | default(loop.index, true) }}">
                <span class="episode-number">{{ ep.episode or loop.index }}</span>
                <span class="episode-title">{{ ep.title or ('E' ~ (ep.episode or loop.index)|string) }}</span>
            </a>
            {% endfor %}
        </div>
    {% endif %}
</section>
{% endif %}

<div id="similar-data"
     class="is-hidden"
     data-plugin="{{ eklenti_adi | default('') }}"
     data-title="{{ content.title | default('') | urlencode }}"
     data-tags="{{ (content.tags if content.tags is string else (content.tags | join(',') if content.tags else '')) | urlencode }}"
     data-current-url="{{ content.url | default('') }}"
     data-content-url="{{ content.url | default('') }}">
</div>

<section id="similar-section" class="similar-section"></section>

<div class="content-back-nav">
    <a href="/eklenti/{{ eklenti_adi }}{{ provider_query }}" class="button button-secondary">
        <i class="fas fa-arrow-left"></i> <span>{{ eklenti_adi }}</span>
    </a>
</div>
{% endblock %}

{% block js %}
<script type="module" src="{{ url_for('static_home', path='JS/components/content-page.min.js') }}" defer></script>
{% endblock %}
