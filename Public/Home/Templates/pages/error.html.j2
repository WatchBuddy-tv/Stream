{#- Bu araç @keyiflerolsun tarafından | @KekikAkademi için yazılmıştır. -#}
{% extends "_html_taban.html.j2" %}

{% block breadcrumbs %}
<nav class="breadcrumbs">
    <a href="/{{ provider_query if provider_query else '' }}" class="breadcrumbs-link"><i class="fas fa-home"></i> <span data-i18n="nav_home">{{ tr('nav_home') }}</span></a>
    <span class="breadcrumbs-sep">/</span>
    <span class="breadcrumbs-current"><i class="fas fa-exclamation-triangle"></i> <span data-i18n="error_title">{{ tr('error_title') }}</span></span>
</nav>
{% endblock %}

{% block icerik %}
<div class="error-page" data-error-code="{{ error_code | default('!', true) }}">
    <div class="error-page-inner">
        <i class="fas fa-exclamation-triangle error-hero-icon"></i>
        <h1 class="error-page-title" data-i18n="error_heading">{{ tr('error_heading') }}</h1>
        <div class="error-box">
            <p>{{ hata }}</p>
        </div>
        <div class="error-actions">
            <a href="/{{ provider_query if provider_query else '' }}" class="button button-primary">
                <i class="fas fa-home"></i> <span data-i18n="back_home">{{ tr('back_home') }}</span>
            </a>
        </div>
    </div>
</div>
{% endblock %}
