{#- Bu araç @keyiflerolsun tarafından | @KekikAkademi için yazılmıştır. -#}
{% extends "_html_taban.html.j2" %}

{% block breadcrumbs %}
<nav class="breadcrumbs">
    <a href="/{{ provider_query if provider_query else '' }}" class="breadcrumbs-link"><i class="fas fa-home"></i> <span class="sr-only" data-i18n="nav_home">{{ tr('nav_home') }}</span></a>
    <span class="breadcrumbs-sep">/</span>
    <a href="/eklenti/{{ eklenti_adi }}{{ provider_query }}" class="breadcrumbs-link">{{ eklenti_adi }}</a>
    <span class="breadcrumbs-sep">/</span>
    <span class="breadcrumbs-current"><i class="fas fa-search"></i> "{{ sorgu }}"</span>
</nav>
{% endblock %}

{% block icerik %}
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-header-title" data-i18n="search_results_for" data-i18n-vars='{"query": "{{ sorgu }}"}'>{{ tr('search_results_for', query=sorgu) }}</h1>
        <div class="page-header-meta">
            <a href="/eklenti/{{ eklenti_adi }}{{ provider_query }}" class="badge badge-link"><i class="fas fa-puzzle-piece"></i> {{ eklenti_adi }}</a>
            {% if results %}<span class="badge badge-outline">{{ tr('search_results_count', count=results|length) }}</span>{% endif %}
        </div>
    </div>
</div>

<div class="plugin-search-shell">
    <form method="GET" action="/ara/{{ eklenti_adi }}" class="search-form">
        <input type="hidden" name="lang" value="{{ lang }}">
        {% if provider_url %}<input type="hidden" name="provider" value="{{ provider_url }}">{% endif %}
        <input type="text" name="sorgu" value="{{ sorgu }}" class="search-input"
            placeholder="{{ tr('search_placeholder') }}"
            data-i18n="search_placeholder" data-i18n-attr="placeholder" required>
        <button type="submit" class="search-button">
            <i class="fas fa-search"></i>
        </button>
    </form>
</div>

<div class="grid grid-results">
    {% for item in results %}
    <a href="/icerik/{{ eklenti_adi }}?url={{ item.url }}{{ provider_query_amp }}" class="poster-card card-fade-in" style="animation-delay: {{ loop.index0 * 40 }}ms" aria-label="{{ item.title }}">
        <div class="poster-card-img{% if not item.poster %} has-error{% endif %}">
            {% if item.poster %}<img src="{{ item.poster }}" alt="{{ item.title }}" loading="lazy" onerror="this.parentElement.classList.add('has-error');this.remove()">{% endif %}
        </div>
        <div class="poster-card-overlay"><span class="poster-card-title">{{ item.title }}</span></div>
    </a>
    {% else %}
    <div class="empty-state-full">
        <i class="fas fa-search"></i>
        <p data-i18n="search_no_results">{{ tr('search_no_results') }}</p>
    </div>
    {% endfor %}
</div>
{% endblock %}
