{#- Bu araç @keyiflerolsun tarafından | @KekikAkademi için yazılmıştır. -#}
{% extends "_html_taban.html.j2" %}
{% block breadcrumbs %}{% endblock %}

{% block icerik %}

{# Hero — compact, centered #}
<section class="page-hero page-hero-home">
    <div class="home-hero-inner">
        <span class="hero-kicker">{{ provider_name }}</span>
        <h1 class="hero-title"><span class="hero-title-wordmark">{{ tr('site_name') }}</span></h1>
        <p class="hero-subtitle" data-i18n="site_tagline">{{ tr('site_tagline') }}</p>

        <div class="home-search-row">
            <div class="search-form" id="global-search-form">
                <input type="text" id="global-search-input" class="search-input"
                    placeholder="{{ tr('search_all_placeholder') }}"
                    data-i18n="search_all_placeholder" data-i18n-attr="placeholder"
                    autocomplete="off">
                <button type="button" id="global-search-button" class="search-button">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>

        <div class="hero-settings-actions">
            <button type="button" id="toggle-provider-settings" class="button button-secondary button-small hero-settings-toggle"
                aria-expanded="false" aria-controls="provider-settings-panel">
                <i class="fas fa-server"></i>
                <span data-i18n="provider_settings">{{ tr('provider_settings') }}</span>
                <i class="fas fa-chevron-down toggle-chevron"></i>
            </button>
            <button type="button" id="toggle-plugin-settings" class="button button-secondary button-small hero-settings-toggle"
                aria-expanded="false" aria-controls="plugin-settings-panel">
                <i class="fas fa-puzzle-piece"></i>
                <span data-i18n="plugin_management">{{ tr('plugin_management') }}</span>
                <i class="fas fa-chevron-down toggle-chevron"></i>
            </button>
        </div>
    </div>
</section>

{# Provider Settings Panel (Collapsible) #}
<section id="provider-settings-panel" class="settings-panel is-hidden">
    <div class="settings-panel-shell">
        <div class="settings-panel-head">
            <div class="settings-panel-copy">
                <span class="settings-panel-kicker" data-i18n="provider_kicker">{{ tr('provider_kicker') }}</span>
                <h2 class="settings-panel-title" data-i18n="provider_settings">{{ tr('provider_settings') }}</h2>
                <p class="settings-panel-subtitle" data-i18n="provider_help_text">{{ tr('provider_help_text') }}</p>
            </div>

            {% if is_remote %}
            <div class="status-badge status-badge-success provider-status-card">
                <i class="fas fa-link"></i>
                <div class="status-badge-copy">
                    <strong>{{ provider_name }}</strong>
                    <small class="status-url">{{ provider_url }}</small>
                </div>
            </div>
            {% else %}
            <div class="status-badge status-badge-info provider-status-card">
                <i class="fas fa-home"></i>
                <div class="status-badge-copy">
                    <strong data-i18n="local_provider">{{ tr('local_provider') }}</strong>
                    <small class="status-url" data-i18n="local_provider_meta">{{ tr('local_provider_meta') }}</small>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="settings-panel-body">
            <div class="provider-input-group">
                <div class="provider-input-wrapper">
                    <i class="fas fa-server"></i>
                    <input type="url" id="provider-url-input" class="search-input"
                        placeholder="{{ tr('provider_url_placeholder') }}"
                        data-i18n="provider_url_placeholder" data-i18n-attr="placeholder"
                        value="{{ provider_url or '' }}">
                </div>
                <button type="button" id="set-provider-button" class="button button-primary">
                    <i class="fas fa-check"></i> <span data-i18n="apply">{{ tr('apply') }}</span>
                </button>
                {% if is_remote %}
                <button type="button" id="reset-provider-button" class="button button-secondary">
                    <i class="fas fa-undo"></i> <span data-i18n="reset">{{ tr('reset') }}</span>
                </button>
                {% endif %}
            </div>

            <div class="provider-support-row">
                <div class="provider-help-card">
                    <i class="fab fa-github"></i>
                    <div class="provider-help-copy">
                        <strong data-i18n="example_provider_info">{{ tr('example_provider_info') }}</strong>
                        <a href="https://github.com/WatchBuddy-tv/ExampleProvider" target="_blank" rel="noopener noreferrer" class="provider-help-link">
                            <span data-i18n="learn_more">{{ tr('learn_more') }}</span>
                            <i class="fas fa-external-link-alt provider-help-link-icon"></i>
                        </a>
                    </div>
                </div>
                {% if not is_remote %}
                <button type="button" id="try-example-button" class="button button-secondary button-small">
                    <i class="fas fa-magic"></i> <span data-i18n="try_example">{{ tr('try_example') }}</span>
                </button>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# Plugin Management Panel (Collapsible) #}
<section id="plugin-settings-panel" class="settings-panel is-hidden">
    <div class="settings-panel-shell">
        <div class="settings-panel-head">
            <div class="settings-panel-copy">
                <span class="settings-panel-kicker" data-i18n="plugin_management">{{ tr('plugin_management') }}</span>
                <h2 class="settings-panel-title" data-i18n="all_plugins">{{ tr('all_plugins') }}</h2>
                <p class="settings-panel-subtitle" data-i18n="plugin_management_subtitle">{{ tr('plugin_management_subtitle') }}</p>
            </div>
        </div>
        <div id="plugin-preferences-list" class="plugin-preferences-list"></div>
    </div>
</section>

{# Search Results (hidden, filled by search.js) #}
<section id="search-results" class="search-results is-hidden">
    <div class="search-results-head">
        <h2><i class="fas fa-search"></i> <span data-i18n="search_results_title">{{ tr('search_results_title') }}</span>: <span id="search-query-display"></span></h2>
        <button id="clear-search" class="button button-secondary button-small">
            <i class="fas fa-times"></i> <span data-i18n="search_clear">{{ tr('search_clear') }}</span>
        </button>
    </div>
    <div id="plugin-filters" class="plugin-filters is-hidden">
        <div class="filters-header">
            <h3><i class="fas fa-filter"></i> <span data-i18n="plugins_filter_title">{{ tr('plugins_filter_title') }}</span></h3>
            <button id="clear-filters" class="button button-small button-secondary">
                <i class="fas fa-times"></i> <span data-i18n="filters_clear">{{ tr('filters_clear') }}</span>
            </button>
        </div>
        <div id="filters-container" class="filters-container"></div>
    </div>
    <div id="search-status" class="search-status"></div>
    <div id="results-grid" class="grid"></div>
</section>

{# Plugin List #}
<section id="plugins-list">
    <div class="section-heading">
        <h2 class="section-title"><i class="fas fa-plug"></i> <span data-i18n="all_plugins">{{ tr('all_plugins') }}</span> <span class="section-count">{{ plugins | length }}</span></h2>
    </div>
    <div class="grid grid-plugins">
        {% for plugin in plugins %}
        <a href="/eklenti/{{ plugin.name }}{{ provider_query }}" class="card plugin-card" data-plugin-name="{{ plugin.name }}" style="--card-index:{{ loop.index0 }}">
            <div class="card-icon">
                {% if plugin.favicon %}
                <img src="{{ plugin.favicon }}" alt="{{ plugin.name }}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling&&(this.nextElementSibling.style.display='');var i=document.createElement('i');i.className='fas fa-film';this.parentElement.appendChild(i);this.remove()">
                {% else %}
                <i class="fas fa-film"></i>
                {% endif %}
            </div>
            <div class="card-body">
                <h3 class="card-title">{{ plugin.name }}</h3>
                <span class="badge badge-lang badge-lang-{{ plugin.language | lower }}">{{ plugin.language | upper }}</span>
            </div>
            <p class="card-desc">{{ plugin.description }}</p>
        </a>
        {% endfor %}
    </div>
</section>

{% endblock %}

{% block js %}
<script id="plugins-data" type="application/json">{{ plugins | tojson }}</script>
<script type="module" src="{{ url_for('static_home', path='JS/global-search.min.js') }}" defer></script>
<script type="module" src="{{ url_for('static_home', path='JS/components/settings-drawer.min.js') }}" defer></script>
{% endblock %}
