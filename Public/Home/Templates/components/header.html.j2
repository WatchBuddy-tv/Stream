{#- Bu araç @keyiflerolsun tarafından | @KekikAkademi için yazılmıştır. -#}

{#- Header Component -#}
<header class="header">
    <div class="container">
        <div class="header-brand">
            <a href="/" class="logo" aria-label="{{ tr('site_name') }}">
                <span class="logo-wordmark" data-i18n="site_name">{{ tr('site_name') }}</span>
            </a>
            <p class="header-tagline" data-i18n="site_tagline">{{ tr('site_tagline') }}</p>
        </div>
        <div class="header-app-links" aria-label="{{ tr('download_app_links') }}">
            <a href="https://play.google.com/store/apps/details?id=com.keyiflerolsun.watchbuddy" class="header-app-link header-app-link-google" target="_blank" rel="noopener noreferrer" aria-label="{{ tr('download_google') }}" title="{{ tr('download_google') }}">
                <i class="fa-brands fa-google-play" aria-hidden="true"></i>
            </a>
            <a href="https://apps.apple.com/us/app/watchbuddy-watch-together/id6758553756" class="header-app-link header-app-link-apple" target="_blank" rel="noopener noreferrer" aria-label="{{ tr('download_apple') }}" title="{{ tr('download_apple') }}">
                <i class="fa-brands fa-apple" aria-hidden="true"></i>
            </a>
        </div>
        <div class="lang-switch" role="group" aria-label="Language">
            <button type="button" class="lang-btn{% if lang == 'tr' %} active{% endif %}" data-lang="tr" aria-pressed="{{ 'true' if lang == 'tr' else 'false' }}">TR</button>
            <button type="button" class="lang-btn{% if lang == 'en' %} active{% endif %}" data-lang="en" aria-pressed="{{ 'true' if lang == 'en' else 'false' }}">EN</button>
            <button type="button" class="lang-btn{% if lang == 'fr' %} active{% endif %}" data-lang="fr" aria-pressed="{{ 'true' if lang == 'fr' else 'false' }}">FR</button>
            <button type="button" class="lang-btn{% if lang == 'ru' %} active{% endif %}" data-lang="ru" aria-pressed="{{ 'true' if lang == 'ru' else 'false' }}">RU</button>
            <button type="button" class="lang-btn{% if lang == 'uk' %} active{% endif %}" data-lang="uk" aria-pressed="{{ 'true' if lang == 'uk' else 'false' }}">UK</button>
            <button type="button" class="lang-btn{% if lang == 'hi' %} active{% endif %}" data-lang="hi" aria-pressed="{{ 'true' if lang == 'hi' else 'false' }}">HI</button>
            <button type="button" class="lang-btn{% if lang == 'zh' %} active{% endif %}" data-lang="zh" aria-pressed="{{ 'true' if lang == 'zh' else 'false' }}">ZH</button>
        </div>
    </div>
</header>
